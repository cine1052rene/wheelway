rules_version = '2';

// Cloud Functions는 Admin SDK로 이 규칙을 무시하고 항상 접근 가능하다.
// 여기서는 클라이언트(앱)가 이 캐시 컬렉션에 직접 읽기/쓰기하는 걸 막기만 하면 된다 —
// 앱은 항상 /api/facilities HTTP 엔드포인트를 통해서만 데이터를 받는다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /facilitiesCache_elevator/{stationId} {
      allow read, write: if false;
    }
    match /facilitiesCache_escalator/{stationId} {
      allow read, write: if false;
    }
    match /facilitiesIndex/{docId} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
